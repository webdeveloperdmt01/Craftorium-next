{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2020",                       // Slightly newer than ES2017, better async/await & features
    "lib": ["dom", "dom.iterable", "esnext"], // Browser + modern JS

    /* JavaScript Support */
    "allowJs": true,                         // Disable JS if you're fully on TypeScript
    "checkJs": false,                         // Don’t type-check JS files

    /* Type Checking */
    "strict": true,                           // Enable all strict checks
    "forceConsistentCasingInFileNames": true, // Enforce import casing rules
    "skipLibCheck": true,                     // Skip type checks in node_modules

    /* Module Resolution */
    "module": "esnext",
    "moduleResolution": "bundler",            // Best for Next.js + ESM
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* JSX & React */
    "jsx": "preserve",                        // Let Next.js handle JSX
    "isolatedModules": true,                  // Required for Next.js
    "noEmit": true,                           // Don’t output compiled files

    /* Project Options */
    "incremental": true,                      // Faster builds w/ cache
    "plugins": [{ "name": "next" }],

    /* Path Aliases */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
